---
interface Props {
  photos: string[];
}

const { photos } = Astro.props;
---

<div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
  {photos.map((url, i) => (
    <button
      class="photo-thumb group relative cursor-zoom-in overflow-hidden bg-film-surface border border-film-border hover:border-film-amber/30 transition-all duration-300"
      data-index={i}
      style="aspect-ratio: 3/2;"
    >
      <img
        src={url}
        alt={`Frame ${i + 1}`}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition-all duration-500 group-hover:scale-[1.03] group-hover:brightness-110"
      />
      <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300" />
      <span class="absolute bottom-2 right-2.5 text-[10px] tracking-widest text-white/30 group-hover:text-white/60 transition-colors duration-200 font-mono">
        {String(i + 1).padStart(2, "0")}
      </span>
    </button>
  ))}
</div>
