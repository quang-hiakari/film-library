---
import type { Visibility } from "../lib/access-control";

interface Props {
  slug: string;
  title: string;
  date: string;
  filmStock?: string;
  coverUrl: string;
  visibility: Visibility;
}

const { slug, title, date, filmStock, coverUrl, visibility } = Astro.props;

const displayDate = new Date(date).toLocaleDateString("en-US", {
  month: "short",
  year: "numeric",
});

const badge = visibility === "private"
  ? { text: "Private", style: "bg-red-500/80" }
  : visibility === "registered"
  ? { text: "Members", style: "bg-gray-700/80" }
  : null;
---

<a href={`/rolls/${slug}`} class="group block">
  <div class="relative overflow-hidden rounded-lg bg-gray-100" style="aspect-ratio: 3/2;">
    <img
      src={coverUrl}
      alt={title}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
    />
    {badge && (
      <span
        class={`absolute right-3 top-3 rounded-full px-2 py-0.5 text-xs font-medium text-white ${badge.style}`}
      >
        {badge.text}
      </span>
    )}
  </div>
  <div class="mt-3">
    <h2 class="text-base font-medium text-gray-900">{title}</h2>
    <p class="mt-0.5 text-sm text-gray-500">
      {displayDate}{filmStock && ` · ${filmStock}`}
    </p>
  </div>
</a>
