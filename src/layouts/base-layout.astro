---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Film Library",
  description = "A personal film photography collection",
} = Astro.props;

const user = Astro.locals.user;
const isAdmin = user?.role === "admin";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-film-border px-6 py-5">
      <div class="mx-auto flex max-w-6xl items-center justify-between">
        <a href="/" class="font-serif text-xl tracking-wide text-film-text hover:text-film-amber transition-colors duration-200">
          Film Library
        </a>
        <nav class="flex items-center gap-6 text-sm">
          {user ? (
            <>
              <span class="text-film-muted">{user.name}</span>
              {isAdmin && (
                <a href="/admin" class="text-film-muted hover:text-film-amber transition-colors duration-200">
                  Admin
                </a>
              )}
              <button
                id="logout-btn"
                class="cursor-pointer text-film-muted hover:text-film-amber transition-colors duration-200"
              >
                Log out
              </button>
            </>
          ) : (
            <>
              <a href="/login" class="text-film-muted hover:text-film-text transition-colors duration-200">
                Log in
              </a>
              <a
                href="/register"
                class="rounded-sm border border-film-amber/60 px-3 py-1.5 text-film-amber hover:bg-film-amber hover:text-film-bg transition-all duration-200"
              >
                Register
              </a>
            </>
          )}
        </nav>
      </div>
    </header>

    <main class="mx-auto w-full max-w-6xl flex-1 px-6 py-10">
      <slot />
    </main>

    <footer class="border-t border-film-border px-6 py-5 text-center text-xs text-film-faint tracking-widest uppercase">
      &copy; {new Date().getFullYear()} Film Library
    </footer>

    {user && (
      <script>
        import { authClient } from "../lib/auth-client";
        document.getElementById("logout-btn")?.addEventListener("click", async () => {
          await authClient.signOut();
          window.location.href = "/";
        });
      </script>
    )}
  </body>
</html>
