---
import BaseLayout from "../layouts/base-layout.astro";

export const prerender = false;

// Already logged in? redirect home.
if (Astro.locals.user) {
  return Astro.redirect("/");
}
---

<BaseLayout title="Log in — Film Library">
  <div class="mx-auto max-w-sm py-12">
    <h2 class="mb-8 text-center text-xl font-light text-gray-900">Log in</h2>

    <form id="login-form" class="space-y-4">
      <div>
        <label for="email" class="block text-sm text-gray-600">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="mt-1 w-full rounded border border-gray-200 px-3 py-2 text-sm focus:border-gray-400 focus:outline-none"
        />
      </div>
      <div>
        <label for="password" class="block text-sm text-gray-600">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          required
          class="mt-1 w-full rounded border border-gray-200 px-3 py-2 text-sm focus:border-gray-400 focus:outline-none"
        />
      </div>
      <p id="error" class="hidden text-sm text-red-600"></p>
      <button
        type="submit"
        class="w-full rounded bg-gray-900 py-2 text-sm font-medium text-white hover:bg-gray-700"
      >
        Log in
      </button>
    </form>

    <p class="mt-6 text-center text-sm text-gray-500">
      No account?
      <a href="/register" class="text-gray-900 underline">Register</a>
    </p>
  </div>

  <script>
    import { authClient } from "../lib/auth-client";

    const form = document.getElementById("login-form") as HTMLFormElement;
    const errorEl = document.getElementById("error") as HTMLParagraphElement;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorEl.classList.add("hidden");
      const data = new FormData(form);
      const { error } = await authClient.signIn.email({
        email: data.get("email") as string,
        password: data.get("password") as string,
      });
      if (error) {
        errorEl.textContent = error.message ?? "Invalid email or password";
        errorEl.classList.remove("hidden");
        return;
      }
      window.location.href = "/";
    });
  </script>
</BaseLayout>
