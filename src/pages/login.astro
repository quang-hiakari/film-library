---
import BaseLayout from "../layouts/base-layout.astro";

export const prerender = false;

if (Astro.locals.user) {
  return Astro.redirect("/");
}
---

<BaseLayout title="Log in — Film Library">
  <div class="mx-auto max-w-sm py-16">
    <h2 class="mb-8 text-center font-serif text-3xl font-light text-film-text">Log in</h2>

    <div class="rounded-sm border border-film-border bg-film-surface p-8">
      <form id="login-form" class="space-y-5">
        <div>
          <label for="email" class="block text-xs tracking-widest uppercase text-film-muted mb-2">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="w-full rounded-sm border border-film-border bg-film-bg px-3 py-2.5 text-sm text-film-text placeholder-film-faint focus:border-film-amber/50 focus:outline-none transition-colors duration-200"
          />
        </div>
        <div>
          <label for="password" class="block text-xs tracking-widest uppercase text-film-muted mb-2">Password</label>
          <input
            id="password"
            name="password"
            type="password"
            required
            class="w-full rounded-sm border border-film-border bg-film-bg px-3 py-2.5 text-sm text-film-text placeholder-film-faint focus:border-film-amber/50 focus:outline-none transition-colors duration-200"
          />
        </div>
        <p id="error" class="hidden text-xs text-red-400"></p>
        <button
          type="submit"
          class="w-full cursor-pointer rounded-sm border border-film-amber/60 py-2.5 text-sm text-film-amber hover:bg-film-amber hover:text-film-bg transition-all duration-200 tracking-wide"
        >
          Log in
        </button>
      </form>
    </div>

    <p class="mt-6 text-center text-xs text-film-muted tracking-wide">
      No account?
      <a href="/register" class="text-film-amber hover:text-film-amber-hover transition-colors duration-200 ml-1">Register</a>
    </p>
  </div>

  <script>
    import { authClient } from "../lib/auth-client";

    const form = document.getElementById("login-form") as HTMLFormElement;
    const errorEl = document.getElementById("error") as HTMLParagraphElement;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorEl.classList.add("hidden");
      const data = new FormData(form);
      const { error } = await authClient.signIn.email({
        email: data.get("email") as string,
        password: data.get("password") as string,
      });
      if (error) {
        errorEl.textContent = error.message ?? "Invalid email or password";
        errorEl.classList.remove("hidden");
        return;
      }
      window.location.href = "/";
    });
  </script>
</BaseLayout>
