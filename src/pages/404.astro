---
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout title="Not found — Film Library">
  <div class="py-24 text-center">
    <p class="font-serif text-8xl font-light text-film-faint">404</p>
    <p class="mt-4 text-sm text-film-muted">Page not found</p>
    <a href="/" class="mt-6 inline-block text-xs tracking-widest uppercase text-film-amber hover:text-film-amber-hover transition-colors duration-200">
      Back to library
    </a>
  </div>
</BaseLayout>
