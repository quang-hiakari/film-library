---
import BaseLayout from "../../layouts/base-layout.astro";
import PhotoGrid from "../../components/photo-grid.astro";
import PhotoLightbox from "../../components/photo-lightbox.astro";
import { getAlbum } from "../../lib/album-service";
import { getDb } from "../../lib/db";

export const prerender = false;

const { slug } = Astro.params;
const env = Astro.locals.runtime?.env;
const user = Astro.locals.user;

if (!slug || !env?.R2 || !env?.DB) {
  return Astro.redirect("/");
}

const db = getDb(env.DB);
const album = await getAlbum(env as any, db, user, slug);

if (!album) {
  if (!user) return Astro.redirect(`/login?redirect=/rolls/${slug}`);
  return new Response(null, { status: 403, statusText: "Forbidden" });
}

const displayDate = new Date(album.date).toLocaleDateString("en-US", {
  month: "long",
  year: "numeric",
});
---

<BaseLayout title={`${album.title} — Film Library`}>
  <div class="mb-8">
    <a href="/" class="text-xs tracking-widest uppercase text-film-muted hover:text-film-amber transition-colors duration-200">
      &larr; Library
    </a>
  </div>

  <header class="mb-10 border-b border-film-border pb-8">
    <h1 class="font-serif text-4xl font-light text-film-text">{album.title}</h1>
    <p class="mt-2 text-xs tracking-widest uppercase text-film-muted">
      {displayDate}
      {album.filmStock && <span class="text-film-faint"> · {album.filmStock}</span>}
      {album.camera && <span class="text-film-faint"> · {album.camera}</span>}
      {album.frames && <span class="text-film-faint"> · {album.frames} frames</span>}
    </p>
    {album.description && (
      <p class="mt-4 max-w-2xl text-sm leading-relaxed text-film-muted">{album.description}</p>
    )}
  </header>

  <PhotoGrid photos={album.photos} />
  <PhotoLightbox photos={album.photos} />
</BaseLayout>
