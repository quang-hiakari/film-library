---
import BaseLayout from "../../layouts/base-layout.astro";
import PhotoGrid from "../../components/photo-grid.astro";
import PhotoLightbox from "../../components/photo-lightbox.astro";
import { getAlbum } from "../../lib/album-service";
import { getDb } from "../../lib/db";

export const prerender = false;

const { slug } = Astro.params;
const env = Astro.locals.runtime?.env;
const user = Astro.locals.user;

if (!slug || !env?.R2 || !env?.DB) {
  return Astro.redirect("/");
}

const db = getDb(env.DB);
const album = await getAlbum(env as any, db, user, slug);

if (!album) {
  if (!user) return Astro.redirect(`/login?redirect=/rolls/${slug}`);
  return new Response(null, { status: 403, statusText: "Forbidden" });
}

const displayDate = new Date(album.date).toLocaleDateString("en-US", {
  month: "long",
  year: "numeric",
});
---

<BaseLayout title={`${album.title} — Film Library`}>
  <div class="mb-8">
    <a href="/" class="text-sm text-gray-400 hover:text-gray-600">&larr; Back</a>
  </div>

  <header class="mb-10">
    <h1 class="text-2xl font-light text-gray-900">{album.title}</h1>
    <p class="mt-1 text-sm text-gray-500">
      {displayDate}
      {album.filmStock && <span> &middot; {album.filmStock}</span>}
      {album.camera && <span> &middot; {album.camera}</span>}
      {album.frames && <span> &middot; {album.frames} frames</span>}
    </p>
    {album.description && (
      <p class="mt-3 max-w-2xl text-sm text-gray-600">{album.description}</p>
    )}
  </header>

  <PhotoGrid photos={album.photos} />
  <PhotoLightbox photos={album.photos} />
</BaseLayout>
