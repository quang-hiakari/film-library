---
import BaseLayout from "../../../layouts/base-layout.astro";
import { getDb } from "../../../lib/db";
import { rolls, rollAccess, user as userTable } from "../../../lib/db-schema";
import { eq } from "drizzle-orm";

export const prerender = false;

const currentUser = Astro.locals.user;
if (!currentUser || currentUser.role !== "admin") return Astro.redirect("/");

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/admin");

const env = Astro.locals.runtime.env;
const db = getDb(env.DB);

const rollRow = await db.select().from(rolls).where(eq(rolls.slug, slug)).limit(1);
const visibility = rollRow[0]?.visibility ?? "registered";

const grants = await db
  .select({ userId: rollAccess.userId, name: userTable.name, email: userTable.email })
  .from(rollAccess)
  .innerJoin(userTable, eq(rollAccess.userId, userTable.id))
  .where(eq(rollAccess.rollSlug, slug));
---

<BaseLayout title={`Admin: ${slug} — Film Library`}>
  <div class="mb-8">
    <a href="/admin" class="text-xs tracking-widest uppercase text-film-muted hover:text-film-amber transition-colors duration-200">
      &larr; Back to admin
    </a>
  </div>

  <header class="mb-10 border-b border-film-border pb-8">
    <h2 class="font-serif text-3xl font-light text-film-text">{slug}</h2>
    <p class="mt-2 text-xs tracking-widest uppercase text-film-muted">
      Visibility: <span class="text-film-amber">{visibility}</span>
    </p>
  </header>

  <section>
    <h3 class="mb-5 text-xs tracking-widest uppercase text-film-muted">User Access</h3>

    {grants.length > 0 ? (
      <ul class="mb-6 space-y-2">
        {grants.map((g) => (
          <li class="flex items-center justify-between rounded-sm border border-film-border bg-film-surface px-4 py-3 text-sm">
            <span class="text-film-text">
              {g.name}
              <span class="ml-2 text-film-muted text-xs">{g.email}</span>
            </span>
            <button
              class="remove-btn cursor-pointer text-xs tracking-widest uppercase text-film-muted hover:text-red-400 transition-colors duration-150"
              data-email={g.email}
            >
              Remove
            </button>
          </li>
        ))}
      </ul>
    ) : (
      <p class="mb-6 font-serif text-lg italic text-film-faint">No users invited yet.</p>
    )}

    <form id="invite-form" class="flex gap-3">
      <input
        id="invite-email"
        type="email"
        required
        placeholder="user@example.com"
        class="flex-1 rounded-sm border border-film-border bg-film-bg px-3 py-2.5 text-sm text-film-text placeholder-film-faint focus:border-film-amber/50 focus:outline-none transition-colors duration-200"
      />
      <button
        type="submit"
        class="cursor-pointer rounded-sm border border-film-amber/60 px-5 py-2.5 text-xs tracking-widest uppercase text-film-amber hover:bg-film-amber hover:text-film-bg transition-all duration-200"
      >
        Invite
      </button>
    </form>
    <p id="invite-msg" class="mt-2 hidden text-xs"></p>
  </section>

  <script define:vars={{ slug }}>
    const msg = document.getElementById("invite-msg");

    function showMsg(text, isError) {
      msg.textContent = text;
      msg.className = `mt-2 text-xs ${isError ? "text-red-400" : "text-film-amber"}`;
      msg.classList.remove("hidden");
      setTimeout(() => msg.classList.add("hidden"), 3000);
    }

    async function callApi(email, action) {
      return fetch("/api/admin/roll-access", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ rollSlug: slug, userEmail: email, action }),
      });
    }

    document.getElementById("invite-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = document.getElementById("invite-email").value;
      const res = await callApi(email, "add");
      if (res.ok) {
        showMsg(`Invited ${email}`, false);
        setTimeout(() => location.reload(), 1000);
      } else {
        const data = await res.json().catch(() => ({}));
        showMsg(data.error || "Failed to invite", true);
      }
    });

    document.querySelectorAll(".remove-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const email = btn.dataset.email;
        const res = await callApi(email, "remove");
        if (res.ok) {
          showMsg(`Removed ${email}`, false);
          setTimeout(() => location.reload(), 1000);
        } else {
          showMsg("Failed to remove", true);
        }
      });
    });
  </script>
</BaseLayout>
